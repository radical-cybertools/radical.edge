#!/bin/sh
# Auto-generated at install time — do not edit.
# Runs the RADICAL Edge service using the Python interpreter and site-packages
# captured when this package was installed.  When ``dragon`` is co-installed
# in the same venv, the service is launched via ``dragon`` so plugins that
# require the Dragon runtime (Rhapsody) initialise correctly.
#
# Log level is controlled by RADICAL_EDGE_LOG_LEVEL (default: INFO).
# Set to DEBUG before submitting to get verbose output in the job log:
#   export RADICAL_EDGE_LOG_LEVEL=DEBUG

export PATH="@BINDIR@:${PATH}"
export PYTHONPATH="@SITEPKGS@:${PYTHONPATH:-}"

DRAGON_PATH=$(command -v dragon  2>/dev/null)
PYTHON_PATH=$(command -v python3 2>/dev/null)

# Decide whether to launch via dragon.  Use it only when:
#   * dragon is installed,
#   * dragon and python3 live in the same bin/ (= same venv),
#   * we are NOT on a SLURM/PBS login node without an allocation —
#     dragon's launch_selector raises in that case.
USE_DRAGON=no
REASON=""
if   [ -z "$DRAGON_PATH" ]; then
    REASON="dragon not installed"
elif [ "$(dirname "$DRAGON_PATH")" != "$(dirname "$PYTHON_PATH")" ]; then
    REASON="external dragon ($DRAGON_PATH)"
elif command -v sbatch >/dev/null 2>&1 && [ -z "$SLURM_JOB_ID" ]; then
    REASON="SLURM login node without allocation"
elif command -v qsub   >/dev/null 2>&1 && [ -z "$PBS_JOBID"    ]; then
    REASON="PBS login node without allocation"
else
    USE_DRAGON=yes
fi

if [ "$USE_DRAGON" = "yes" ]; then
    echo "[radical-edge] starting with dragon ($DRAGON_PATH)" >&2
    exec dragon "@BINDIR@/radical-edge-service.py" "$@"
else
    echo "[radical-edge] starting with python ($PYTHON_PATH) — $REASON" >&2
    exec "$PYTHON_PATH" "@BINDIR@/radical-edge-service.py" "$@"
fi
